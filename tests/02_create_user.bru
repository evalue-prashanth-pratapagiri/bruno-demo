meta {
  name: Create User
  type: graphql
  seq: 2
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  mutation CreateUser($name: String!, $email: String!) {
    createUser(name: $name, email: $email) {
      id
      name
      email
    }
  }
}

body:graphql:vars {
  {
    "name": "Carol Smith",
    "email": "carol@example.com"
  }
}

tests {
  const { assertSuccess, assertUserShape } = require('./lib/graphql');

  test("status 200 and no GraphQL errors", function() {
    assertSuccess(res);
  });

  test("user created with correct fields", function() {
    const user = res.body.data.createUser;
    assertUserShape(user, { name: "Carol Smith", email: "carol@example.com" });
    expect(user.id).to.be.a("string");
  });

  test("store created user id for chaining", function() {
    bru.setVar("createdUserId", res.body.data.createUser.id);
  });
}
