meta {
  name: Update User
  type: graphql
  seq: 4
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  mutation UpdateUser($id: ID!, $name: String, $email: String) {
    updateUser(id: $id, name: $name, email: $email) {
      id
      name
      email
    }
  }
}

body:graphql:vars {
  {
    "id": "{{createdUserId}}",
    "name": "Carol Johnson",
    "email": "carol.johnson@example.com"
  }
}

tests {
  const { assertSuccess, assertUserShape } = require('./lib/graphql');

  test("status 200 and no GraphQL errors", function() {
    assertSuccess(res);
  });

  test("user fields are updated", function() {
    assertUserShape(res.body.data.updateUser, {
      id: bru.getVar("createdUserId"),
      name: "Carol Johnson",
      email: "carol.johnson@example.com"
    });
  });
}
