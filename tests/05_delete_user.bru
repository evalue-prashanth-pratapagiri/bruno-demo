meta {
  name: Delete User
  type: graphql
  seq: 5
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  mutation DeleteUser($id: ID!) {
    deleteUser(id: $id)
  }
}

body:graphql:vars {
  {
    "id": "{{createdUserId}}"
  }
}

tests {
  const { assertSuccess } = require('./lib/graphql');

  test("status 200 and no GraphQL errors", function() {
    assertSuccess(res);
  });

  test("deleteUser returns true", function() {
    expect(res.body.data.deleteUser).to.equal(true);
  });
}
