meta {
  name: Get User By ID
  type: graphql
  seq: 3
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  query GetUser($id: ID!) {
    user(id: $id) {
      id
      name
      email
    }
  }
}

body:graphql:vars {
  {
    "id": "{{createdUserId}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("no GraphQL errors", function() {
    expect(res.body.errors).to.be.undefined;
  });

  test("returns the user created in previous test", function() {
    const user = res.body.data.user;
    expect(user).to.not.be.null;
    expect(user.id).to.equal(bru.getVar("createdUserId"));
    expect(user.name).to.equal("Carol Smith");
    expect(user.email).to.equal("carol@example.com");
  });
}
