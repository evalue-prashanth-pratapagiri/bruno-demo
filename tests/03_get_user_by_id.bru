meta {
  name: Get User By ID
  type: graphql
  seq: 3
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  query GetUser($id: ID!) {
    user(id: $id) {
      id
      name
      email
    }
  }
}

body:graphql:vars {
  {
    "id": "{{createdUserId}}"
  }
}

tests {
  const { assertSuccess, assertUserShape } = require('./lib/graphql');

  test("status 200 and no GraphQL errors", function() {
    assertSuccess(res);
  });

  test("returns the user created in previous test", function() {
    assertUserShape(res.body.data.user, {
      id: bru.getVar("createdUserId"),
      name: "Carol Smith",
      email: "carol@example.com"
    });
  });
}
