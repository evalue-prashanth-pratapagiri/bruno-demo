{
  "name": "graphql-bruno-demo",
  "version": "1.0.0",
  "type": "module",
  "description": "Apollo Server 4 GraphQL service with Bruno integration tests",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"npx tsx src/server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "cd tests && npx bru run --env local"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@usebruno/cli": "^3.2.2",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
